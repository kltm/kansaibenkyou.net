source "https://rubygems.org"

# Use the github-pages gem to ensure local builds match the
# GitHub Pages build environment exactly. This pins jekyll and all
# allowlisted plugins to the versions GH Pages currently uses.
gem "github-pages", group: :jekyll_plugins

# Markdown processor (kramdown is the GH Pages default).
gem "kramdown-parser-gfm"

# Required by the github-pages gem on some platforms.
gem "webrick"
